# Google Analytics 4
GA4_PROPERTY_ID=your_ga4_property_id

# Service Account (for GA4 and GSC - server-to-server auth)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# OAuth 2.0 (for YouTube Analytics and user login)
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret

# YouTube Analytics
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# Flask
FLASK_SECRET_KEY=generate-a-random-secret-key-here
FLASK_DEBUG=true
PORT=5000
