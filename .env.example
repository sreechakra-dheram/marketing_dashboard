# =============================================================================
# Raven Labs Marketing Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is in .gitignore.
# =============================================================================


# ── Google — Account A (GA4 + GSC, all 3 orgs) ───────────────────────────────
# One service account JSON covers RavenLabs, SDH, and Linkstone.
# The service account email must be added as Viewer in each org's:
#   - Google Analytics 4 property (GA4 Admin > Property Access Management)
#   - Google Search Console site (Search Console > Settings > Users and permissions)

GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# GA4 Property IDs — find in GA4 Admin > Property Settings
GA4_PROPERTY_ID_RAVENLABS=
GA4_PROPERTY_ID_SDH=
GA4_PROPERTY_ID_LINKSTONE=

# Search Console site URLs — must match exactly as registered in GSC
# Format: https://example.com/ or sc-domain:example.com
GSC_SITE_URL_RAVENLABS=
GSC_SITE_URL_SDH=
GSC_SITE_URL_LINKSTONE=


# ── YouTube — Account B (separate Google account from Account A) ──────────────
# The YouTube channel UCe76_AMrsZmthhZaXLKmS8Q lives on a DIFFERENT Google
# account from the one used for GA4/GSC above.
# OAuth credentials were created in Account B's Google Cloud project.
# Steps:
#   1. Fill in YOUTUBE_CLIENT_ID and YOUTUBE_CLIENT_SECRET from Account B
#   2. Deploy the app
#   3. Visit /admin/auth/youtube and sign in with Account B
#   4. YOUTUBE_REFRESH_TOKEN is auto-saved — do NOT set it manually here

YOUTUBE_CHANNEL_ID=UCe76_AMrsZmthhZaXLKmS8Q
YOUTUBE_CLIENT_ID=                # OAuth client ID from Account B's GCP project
YOUTUBE_CLIENT_SECRET=            # OAuth client secret from Account B's GCP project
YOUTUBE_REFRESH_TOKEN=            # Auto-saved after OAuth flow — leave blank


# ── LinkedIn (RavenLabs only) ─────────────────────────────────────────────────
# Required scopes: r_organization_social, r_organization_followers, rw_organization_admin
# Get token from: LinkedIn Developer Portal > Your App > Auth > OAuth 2.0 tools
# NOTE: Regenerate if previously exposed — old token must not be reused.

LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID_RAVENLABS=        # Numeric org ID from linkedin.com/company/<slug>/admin


# ── Meta — Facebook + Instagram (RavenLabs + SDH) ────────────────────────────
# Single long-lived Page Access Token covers Facebook and Instagram for all orgs.
# Get from: Meta for Developers > Your App > Tools > Graph API Explorer
#   > Select Page > Generate long-lived token (60 days)
# Required permissions: pages_read_engagement, instagram_basic, instagram_manage_insights

# Facebook + Instagram — per org, each with its own Page Access Token
# Get tokens from: Meta for Developers > Tools > Graph API Explorer
#   > Select each Page or Instagram account > Generate Access Token
#   > Extend to long-lived token (60 days):
#     GET https://graph.facebook.com/oauth/access_token
#         ?grant_type=fb_exchange_token&client_id=APP_ID&client_secret=APP_SECRET&fb_exchange_token=SHORT_TOKEN
# Required FB permissions:  pages_read_engagement, pages_show_list
# Required IG permissions:  instagram_basic, instagram_manage_insights

# Facebook — RavenLabs
FACEBOOK_ACCESS_TOKEN_RAVENLABS=
FACEBOOK_PAGE_ID_RAVENLABS=

# Facebook — SDH
FACEBOOK_ACCESS_TOKEN_SDH=
FACEBOOK_PAGE_ID_SDH=

# Instagram — RavenLabs
INSTAGRAM_ACCESS_TOKEN_RAVENLABS=
INSTAGRAM_ACCOUNT_ID_RAVENLABS=    # GET /{fb-page-id}?fields=instagram_business_account

# Instagram — SDH
INSTAGRAM_ACCESS_TOKEN_SDH=
INSTAGRAM_ACCOUNT_ID_SDH=          # GET /{fb-page-id}?fields=instagram_business_account

# Instagram — Linkstone
INSTAGRAM_ACCESS_TOKEN_LINKSTONE=
INSTAGRAM_ACCOUNT_ID_LINKSTONE=    # GET /{fb-page-id}?fields=instagram_business_account


# ── Twitter / X (future — placeholder only) ───────────────────────────────────
# Tab shown as "Coming Soon" — no API calls yet.
# Get from: developer.twitter.com > Project > App > Keys and Tokens > Bearer Token

TWITTER_BEARER_TOKEN=


# ── Google Ads (future — placeholder only) ────────────────────────────────────
# Tab shown as "Coming Soon — Pending Developer Account Approval".
# Set once a Google Ads Developer Token is approved.

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=


# ── Ubersuggest (future — placeholder only) ───────────────────────────────────
# Planned for SEO keyword tracking tab.

UBERSUGGEST_API_KEY=


# ── Access Control (future login re-enablement) ───────────────────────────────
# Comma-separated list of Google accounts allowed to log in.
# Not enforced currently — preserved for when auth is re-enabled.

ALLOWED_EMAILS=email1@gmail.com,email2@gmail.com


# ── Flask ─────────────────────────────────────────────────────────────────────
# Generate secret key: python -c "import secrets; print(secrets.token_hex(32))"

FLASK_SECRET_KEY=
FLASK_DEBUG=false
PORT=8080
